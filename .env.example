# Required Environment Variables

# App
NEXT_PUBLIC_APP_NAME=SplitFare
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Privy Authentication
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# PRIVY_JWT_VERIFICATION_KEY=  # Optional: for faster local JWT verification

# ENS & Blockchain
NEXT_PUBLIC_CHAIN=sepolia
NEXT_PUBLIC_ENS_DOMAIN=splitfare.eth
NEXT_PUBLIC_CID_REGISTRY_ADDRESS=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ANCHOR_PRIVATE_KEY=

# Namespace (ENS subdomain registration — get key at https://dev.namespace.ninja)
NAMESPACE_API_KEY=

# Storacha (IPFS/IPLD storage)
STORACHA_KEY=
STORACHA_PROOF=
# IPFS_GATEWAY_HOST=storacha.link  # Optional: override default IPFS gateway

# Upstash Redis (rate limiting — optional in dev)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Resend (email notifications)
RESEND_API_KEY=
EMAIL_FROM=SplitFare <noreply@splitfare.io>

# Cron jobs (production: required, min 16 chars; send Authorization: Bearer <value> to /api/cron/bundle)
# CRON_SECRET=

# PWA theming
NEXT_PUBLIC_PWA_THEME_COLOR=#000000
NEXT_PUBLIC_PWA_BACKGROUND_COLOR=#000000
